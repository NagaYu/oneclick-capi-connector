{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "builds": [
    {
      "src": "dist/server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/tracker.js", "dest": "dist/server/index.js" },
    { "src": "/healthz", "dest": "dist/server/index.js" },
    { "src": "/api/events", "dest": "dist/server/index.js" },
    { "src": "/(.*)", "dest": "dist/server/index.js" }
  ]
}
