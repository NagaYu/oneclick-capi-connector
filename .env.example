# ===========================================================================
# OneClick CAPI Connector — Environment Template
# ---------------------------------------------------------------------------
# Copy to ".env" and fill in your values. NEVER commit the real ".env".
#   cp .env.example .env
# ===========================================================================

# --- Server -----------------------------------------------------------------
# Port the relay listens on. Vercel/Heroku inject this automatically.
PORT=8080

# Comma-separated list of allowed browser Origins (CORS). Leave EMPTY only for
# local dev — always set this in production to your storefront domain(s).
#   e.g. ALLOWED_ORIGINS=https://shop.example.com,https://www.example.com
ALLOWED_ORIGINS=

# Optional shared secret. When set, the client must send it as the
# "X-Relay-Secret" header. Blocks anonymous open-relay abuse.
RELAY_SHARED_SECRET=

# Default phone country code (no "+") for national-format numbers.
# Japan = 81, US = 1, UK = 44, etc.
PHONE_COUNTRY_CODE=81

# Per-request upstream timeout (ms).
REQUEST_TIMEOUT_MS=8000

# DRY-RUN mode: run the full normalize→hash→validate pipeline but DO NOT send to
# Meta/Google. Lets you boot and verify the relay with NO ad-platform credentials.
# Set to "false" (and fill in the tokens below) to start sending real conversions.
DRY_RUN=false

# --- Background retry queue (in-memory, no external infra) -------------------
# Total attempts including the first send.
RETRY_MAX_ATTEMPTS=4
# Base backoff delay (ms) before the first retry.
RETRY_BASE_DELAY_MS=500
# Hard ceiling on any single backoff delay (ms).
RETRY_MAX_DELAY_MS=30000
# Exponential growth factor per attempt.
RETRY_FACTOR=2
# Add randomized jitter to spread retries (true/false).
RETRY_JITTER=true
# Max simultaneous retry executions.
RETRY_CONCURRENCY=8

# --- Meta Conversions API ---------------------------------------------------
META_ENABLED=true
# Your Pixel / Dataset ID (Events Manager → Data Sources).
META_PIXEL_ID=
# System-user access token with "ads_management" permission.
META_ACCESS_TOKEN=
# Optional: Events Manager → Test Events → test code (e.g. TEST12345).
# Leave EMPTY in production.
META_TEST_EVENT_CODE=
# Graph API version.
META_API_VERSION=v21.0

# --- Google Ads Enhanced Conversions ----------------------------------------
GOOGLE_ENABLED=false
# OAuth2 access token (Bearer). Refresh out-of-band; this server reads it as-is.
GOOGLE_ACCESS_TOKEN=
# Google Ads developer token.
GOOGLE_DEVELOPER_TOKEN=
# Target customer ID (digits only, no dashes).
GOOGLE_CUSTOMER_ID=
# Manager/MCC login customer ID (digits only). Optional.
GOOGLE_LOGIN_CUSTOMER_ID=
# Conversion action resource name.
#   e.g. customers/1234567890/conversionActions/987654321
GOOGLE_CONVERSION_ACTION_RESOURCE_NAME=
# Google Ads API version.
GOOGLE_API_VERSION=v17
